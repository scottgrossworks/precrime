generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Client {
  id             String    @id @default(cuid())
  name           String
  email          String?   // NOT unique: a valid shared inbox (e.g. inquiries@acme.com) may legitimately belong to two clients
  phone          String?
  company        String?
  website        String?
  clientNotes    String?
  segment        String?   // audience segment: defined per deployment
  dossier        String?   // accumulated intelligence — timestamped prose
  targetUrls     String?   // JSON: [{url, type, label}]
  draft          String?   // current best outreach draft
  draftStatus    String?   // "brewing" | "ready" | "sent"
  sentAt         DateTime? // when draft was actually sent via Gmail
  warmthScore    Float?    // DEPRECATED — use dossierScore. Kept for backwards compat.
  dossierScore   Int?      // continuous, unbounded — computed by score_client
  contactGate    Boolean   @default(false) // binary: has real named contact + direct email
  intelScore     Int?      // D2+D3 — set by enrichment agent after scraping
  lastEnriched   DateTime?
  lastQueueCheck DateTime? // DB cursor + factlet watermark
  source         String?   // how this client entered the DB
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  bookings       Booking[]
}

model Booking {
  id               String    @id @default(cuid())
  clientId         String
  title            String?
  description      String?
  notes            String?
  location         String?
  startDate        DateTime?
  endDate          DateTime?
  startTime        String?
  endTime          String?
  duration         Float?
  hourlyRate       Float?
  flatRate         Float?
  totalAmount      Float?
  status           String    @default("brewing")  // cold | brewing | hot. Set ONLY by the Judge (computeBookingTargetScore): procedural gates + LLM PMF judge. See DOCS/CLASSIFICATION.md. (The `shared` boolean tracks acted-on; status returns to cold after an action.)
  source           String?
  sourceUrl        String?
  trade            String?
  zip              String?
  shared           Boolean   @default(false)
  sharedTo         String?   // "leedz_api" | "email_share" | "email_user"
  sharedAt         BigInt?
  leedPrice        Int?
  leedId           String?   // returned by createLeed MCP tool
  squarePaymentUrl String?   // Leedz desktop (INVOICER) field; PRECRIME never writes it -- present so the shared DB satisfies the desktop's Prisma reads
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  client           Client    @relation(fields: [clientId], references: [id])
}

model Factlet {
  id        String   @id @default(cuid())
  content   String
  source    String
  createdAt DateTime @default(now())
}

// ============================================================================
// SESSION + SESSIONEVENT — workflow accountability layer
// ============================================================================
// A Session represents one bounded unit of agent work (e.g. "find 5 convention
// exhibitors"). The agent calls pipeline.start_session to open one and gets
// back a server-issued session_id it cannot forge. Subsequent save calls may
// include session_id; the server logs each success/failure as a SessionEvent.
// pipeline.report_session aggregates those events server-side and returns the
// truth — the model cannot lie about counts because the server queries its
// own append-only log. See DOCS/CLAUDE.md (truth-in-tools layer).
// ============================================================================

model Session {
  id          String         @id                       // server-issued, e.g. "ses_<cuid>"
  workflow    String                                    // "convention-leeds" | "enrichment" | "drafting" | ad-hoc
  status      String         @default("active")        // "active" | "complete" | "abandoned"
  targetCount Int?                                      // optional declared target (e.g. 5 clients)
  startedAt   DateTime       @default(now())
  finishedAt  DateTime?
  metadata    String?                                   // JSON blob for workflow-specific params
  events      SessionEvent[]
}

model SessionEvent {
  id        String   @id @default(cuid())
  sessionId String
  ts        DateTime @default(now())
  action    String                                      // "save_success" | "save_failed" | "report" | extensible
  payload   String?                                     // JSON: {clientId, name, score} or {name, error, attemptedPatch} etc
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([action])
}

// ============================================================================
// SOURCE -- REMOVED. Scrape sources now live in per-channel markdown files
// (skills/*-factlet-harvester/*_sources.md, skills/source-discovery/*.md) which
// are the single source of truth. The server reads them into an in-memory index
// at startup (server/mcp/sourceStore.js) and is the sole writer; pipeline
// next_source/mark_source/add_sources operate on markdown, not a DB table.
// Existing Source rows are exported to markdown by scripts/migrate-db.js.
// ============================================================================

// ============================================================================
// TASK -- the unit of work for the new Planner/Worker/Judge architecture
// ============================================================================
// See DOCS/WHAT_I_LEARNED.md. A Task is one bounded job created by the
// Planner (MCP). Workers claim Tasks atomically, do the work, then call
// complete_task. Finished Tasks are kept as a SQLite audit trail until the
// recycler purges them.
//
// Lifecycle: ready -> claimed -> done|failed|cancelled
// Stale claimed Tasks (claimedAt older than claim timeout) are reclaimable.
// ============================================================================

model Task {
  id          String    @id @default(cuid())
  type        String                                 // DISCOVER_SOURCES | SCRAPE_SOURCE | ENRICH_CLIENT | APPLY_FACTLET | JUDGE_AFFECTED | SHOW_HOT_LEEDZ | SHARE_BOOKING
  status      String    @default("ready")            // ready | claimed | done | failed | cancelled
  sessionId   String?                                // optional Session/run container
  targetType  String?                                // Source | Client | Booking | Factlet | none
  targetId    String?                                // id of the target object
  input       String?                                // JSON
  output      String?                                // JSON, includes affected ids when relevant
  error       String?
  claimedAt   DateTime?
  claimedBy   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  finishedAt  DateTime?

  @@index([status])
  @@index([type])
  @@index([sessionId])
  @@index([targetType, targetId])
}
// Config table removed: runtime config is now an in-memory struct built at
// startup (server/mcp/mcp_server.js buildRuntimeConfig) from DOCS/VALUE_PROP.md
// (identity) + precrime_config.json (LLM/runtime). This aligns PRECRIME with the
// Leedz desktop schema contract, which also drops Config. Changes require a
// server restart. See DOCS/wiki (config) for the rationale.

// SquareConnection -- owned by the Leedz desktop client (INVOICER); durable Square
// OAuth state. PRECRIME never reads or writes it, but it is declared here so the
// unified shared SQLite database carries the table and the desktop's Prisma client
// finds it. Mirrors the contract at INVOICER/client/DOCS/SQLITE_SCHEMA.md.
model SquareConnection {
  id           String   @id @default(cuid())
  accessToken  String?
  refreshToken String?
  expiresAt    BigInt?
  merchantId   String?
  locationId   String?
  state        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
