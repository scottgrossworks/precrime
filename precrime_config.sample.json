{
  "_comment": "PRECRIME runtime/API config sample. Copy to precrime_config.json and fill in API keys locally. Product/sales truth (company, pitch, trade, buyers, geography) lives in DOCS/VALUE_PROP.md -- never here.",
  "deploymentName": "MyProject",
  "databaseFile": "data/myproject.sqlite",
  "defaultMode": "interactive",
  "apiKeys": {
    "openai": "",
    "anthropic": "",
    "openrouter": "",
    "tavily": "",
    "scrapecreators": "",
    "xai": ""
  },
  "llm": {
    "provider": "openrouter",
    "model": "anthropic/claude-haiku-4-5",
    "baseUrl": "https://openrouter.ai/api/v1"
  },
  "tasks": {
    "limits": {
      "DISCOVER_SOURCES": 1,
      "SCRAPE_SOURCE": 5,
      "APPLY_FACTLET": 5,
      "ENRICH_CLIENT": 10,
      "JUDGE_AFFECTED": 5,
      "SHOW_HOT_LEEDZ": 1,
      "SHARE_BOOKING": 3,
      "DRAFT_OUTREACH": 5
    },
    "sessionBudgets": {
      "DISCOVER_SOURCES": 1,
      "SCRAPE_SOURCE": 25,
      "APPLY_FACTLET": 50,
      "ENRICH_CLIENT": 50,
      "JUDGE_AFFECTED": 50,
      "SHOW_HOT_LEEDZ": 1,
      "SHARE_BOOKING": 10,
      "DRAFT_OUTREACH": 25
    },
    "workflowStrategy": {
      "factletBacklogDiscoveryPause": 25
    }
  },
  "recycler": {
    "factletStaleDays": 180,
    "taskRetentionDays": 30,
    "claimTimeoutMinutes": 10
  },
  "paths": {
    "valueProp": "DOCS/VALUE_PROP.md",
    "rssConfig": "rss/rss-scorer-mcp/rss_config.json",
    "redditConfig": "reddit/reddit_config.json",
    "igConfig": "ig/ig_config.json",
    "gmailConfig": "server/mcp/gmail_mcp_config.json"
  }
}
