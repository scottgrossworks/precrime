{
  "manifest_version": 3,
  "name": "LeedzEx",
  "version": "1.0",
  "description": "Capture employers from any webpage.",
  "permissions": [
    "scripting",
    "activeTab",
    "storage",
    "tabs",
    "sidePanel"
  ],
  "host_permissions": [
    "http://localhost:3000/",
    "*://*.linkedin.com/*"
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Open LeedzEx"
  },

  "side_panel": {
    "default_path": "sidebar.html",
    "default_open": false
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "js/background.js",
    "type": "module"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "css/*",
        "js/*",
        "sidebar.html",
        "icons/*"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}


