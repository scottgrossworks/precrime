{
  "server": {
    "port": 3001,
    "logFile": "../logs/rss_server.log"
  },
  "processing": {
    "checkInterval": "*/55 * * * *",
    "maxItemsPerFeed": 20,
    "relevanceThreshold": 3,
    "matchThreshold": 0.5,
    "earlyExitEnabled": true,
    "earlyExitCount": 4,
    "earlyExitMinScore": 80,
    "maxArticlesPerFeed": 2,
    "contentCharLimit": 400
  },
  "scoring": {
    "globalKeywordWeight": 1,
    "feedKeywordWeight": 3,
    "maxKeywordMatches": 10,
    "multiplier": 2,
    "recencyBonus": 5,
    "fullContentBonus": 2
  },
  "keywords": {
    "global": [
      "event", "convention", "expo", "trade show", "conference",
      "wedding", "corporate event", "gala", "fundraiser", "festival",
      "party", "celebration", "venue", "exhibitor", "planner",
      "booking", "vendor", "entertainment", "photo booth", "DJ",
      "caterer", "decorator", "rental", "hire"
    ]
  },
  "blacklist": []
}
