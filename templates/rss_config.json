{
  "server": {
    "port": 3001,
    "logFile": "../logs/rss_server.log"
  },
  "processing": {
    "checkInterval": "*/55 * * * *",
    "maxItemsPerFeed": 20,
    "relevanceThreshold": 3,
    "matchThreshold": 0.5,
    "earlyExitEnabled": true,
    "earlyExitCount": 4,
    "earlyExitMinScore": 80,
    "maxArticlesPerFeed": 2,
    "contentCharLimit": 400
  },
  "scoring": {
    "globalKeywordWeight": 1,
    "feedKeywordWeight": 3,
    "maxKeywordMatches": 10,
    "multiplier": 2,
    "recencyBonus": 5,
    "fullContentBonus": 2
  },
  "keywords": {
    "global": [],
    "_note": "keywords are derived from DOCS/VALUE_PROP.md at scorer startup (see index.js loadKeywordsFromValueProp). Do NOT hardcode here."
  },
  "blacklist": []
}